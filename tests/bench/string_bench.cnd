fn string_test() -> i64 {
    let mut s: str = ""
    let max_iter: i64 = 10000
    let mut i: i64 = 0
    loop {
        if i >= max_iter { break }
        s = str_concat(s, "A")
        i = i + 1
    }
    return str_len(s)
}

fn main() -> unit {
    let start = time_now_ms()
    let sum = string_test()
    let end = time_now_ms()
    let diff = end - start
    print("string_test len: ")
    println(_cnd_int_to_str(sum))
    print("Time: ")
    print(_cnd_int_to_str(diff))
    println("ms")
    return unit
}
